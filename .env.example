# =================================================================
# GESTIÓN DE TALLER - CONFIGURACIÓN DE ENTORNO
# =================================================================
# Copia este archivo a .env y configura los valores

# ================== CONFIGURACIÓN BÁSICA ==================
PROJECT_NAME=Gestión de Taller API
API_V1_STR=/api/v1

# IMPORTANTE: Cambiar en producción por una clave segura de 32+ caracteres
# Generar con: openssl rand -hex 32
SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA_EN_PRODUCCION

# Tokens de acceso
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# ================== BASE DE DATOS ==================
# Desarrollo: SQLite
# SQLALCHEMY_DATABASE_URI=sqlite:///./sql_app.db

# Producción: PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_USER=lubri_admin
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=lubricentro_db
SQLALCHEMY_DATABASE_URI=postgresql://lubri_admin:PASSWORD@localhost:5433/lubricentro_db

# ================== CONFIGURACIÓN SMTP ==================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password

# ================== SEGURIDAD - RATE LIMITING ==================

# Login - Protección contra fuerza bruta
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900

# API - Límites generales
API_RATE_LIMIT_PER_MINUTE=60
IP_RATE_LIMIT_PER_MINUTE=100

# Endpoints sensibles
PASSWORD_RESET_RATE_LIMIT=3
REGISTRATION_RATE_LIMIT=5

# ================== SEGURIDAD - BLOQUEO DE CUENTA ==================
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# ================== SEGURIDAD - CONTRASEÑAS ==================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# ================== SEGURIDAD - AUDITORÍA ==================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/security_audit.log
AUDIT_LOG_MAX_BYTES=10485760
AUDIT_LOG_BACKUP_COUNT=5

# ================== SEGURIDAD - HEADERS ==================
SECURITY_HEADERS_ENABLED=true

# ================== MODO DEBUG ==================
# IMPORTANTE: Desactivar en producción
DEBUG_MODE=false
