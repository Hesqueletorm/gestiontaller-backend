# ==========================================
# .dockerignore para Backend
# ==========================================

# Entornos virtuales
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class

# Archivos de desarrollo
.env
.env.local
.env.*.local

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Base de datos local (SQLite)
*.db
*.sqlite3

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Archivos temporales
*.tmp
*.temp
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentación
docs/
*.md
!README.md

# Docker
Dockerfile
docker-compose*.yml
.dockerignore
